# Production: copy to .env.production (used at npm run build).
# Use the same registrable domain as Spring SESSION (e.g. .ecommerce.com) so login + Stripe return stay logged in.
# Gateway / API — same-site or CORS-configured origin:
NEXT_PUBLIC_API_BASE=https://api.ecommerce.com
# If the Next app is served at https://www.ecommerce.com and API is same-origin under /api, you can use:
# NEXT_PUBLIC_API_BASE=https://www.ecommerce.com
