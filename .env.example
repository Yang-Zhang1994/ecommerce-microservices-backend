# Oregon (us-west-2) RDS：从 AWS RDS 控制台复制「端点」主机名（不要带 :5432）
RDS_ENDPOINT=xxx.xxxx.us-west-2.rds.amazonaws.com
RDS_USERNAME=postgres
RDS_PASSWORD=your-password

# S3 直传（图片等）：需配置凭证，否则上传会报 500
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# 可选：若 S3 桶名称不同，可覆盖
# AWS_S3_BUCKET=ecommerce-uploads-oregon

# --- Spring Session (auth + order; optional cart) — must match the hostname users use for login + mall ---
# Production SSO on your apex domain (e.g. *.yangzhangtech.online): parent domain for www + api + mall.
# auth-server uses a host-only SESSION on localhost/127.0.0.1 even when these are set (Google OAuth works locally).
# GULIMALL_SESSION_COOKIE_DOMAIN=.yangzhangtech.online
# GULIMALL_SESSION_COOKIE_SECURE=true

# --- Mall public URL (same registrable domain as SESSION). Stripe redirects here after pay; no trailing slash. ---
# Local:  GULIMALL_MALL_PUBLIC_ORIGIN=http://localhost:3001
# Prod:   GULIMALL_MALL_PUBLIC_ORIGIN=https://www.yangzhangtech.online
# Optional full overrides (otherwise built from GULIMALL_MALL_PUBLIC_ORIGIN):
# ORDER_STRIPE_SUCCESS_URL=https://www.yangzhangtech.online/order/success?paid=1
# ORDER_STRIPE_CANCEL_URL=https://www.yangzhangtech.online/order/pay?cancelled=1

# --- gulimall-gateway：RequestRateLimiter 需要 Redis（Compose 中网关已默认 SPRING_DATA_REDIS_HOST=redis）---
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_DATA_REDIS_PORT=6379
# 令牌桶（每秒补充 / 桶容量）
# GATEWAY_RATELIMIT_API_REPLENISH=100
# GATEWAY_RATELIMIT_API_BURST=200
# GATEWAY_RATELIMIT_ORDER_REPLENISH=80
# GATEWAY_RATELIMIT_ORDER_BURST=160
# GATEWAY_RATELIMIT_AUTH_REPLENISH=120
# GATEWAY_RATELIMIT_AUTH_BURST=240
# GATEWAY_RATELIMIT_LOGIN_REPLENISH=15
# GATEWAY_RATELIMIT_PAY_REPLENISH=30
# GATEWAY_RATELIMIT_SUBMIT_REPLENISH=20

# Stripe webhook admin replay (optional)
# ORDER_STRIPE_WEBHOOK_REPLAY_SECRET=change-me-long-random

# gulimall-auth-server：Twilio 发短信验证码（三项都填才会真发；留空则仅打 stub 日志）
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+12065551234

# Google OAuth (auth-server). Register redirect URI in Google Cloud Console.
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# Prod redirect (must match Console → Authorized redirect URIs):
# GULIMALL_GOOGLE_REDIRECT_URI=https://www.yangzhangtech.online/api/auth/login/oauth2/code/{registrationId}
# GULIMALL_OAUTH2_SUCCESS_URL=https://mall.yangzhangtech.online/
# GULIMALL_OAUTH2_FAILURE_URL=https://mall.yangzhangtech.online/login?error
